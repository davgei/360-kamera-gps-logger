# Configuration for the auto-started logger app.
# This file is committed (it holds NO secrets — keep the TeamViewer token out).
# Edit it, commit and push; every Pi picks up the change on its next boot.

# Command that starts the logger. Empty = no app yet (the service no-ops).
# Use `python3` — it resolves to the venv below when APP_REQUIREMENTS is set,
# otherwise to the system Python 3. Examples:
#   APP_CMD="python3 main.py"
#   APP_CMD="python3 -m logger"
APP_CMD=""

# Working directory for APP_CMD. Empty = repo root.
APP_WORKDIR=""

# Optional pip requirements file (relative to repo root). When set, deps are
# installed into a virtualenv on each code update. Empty = skip.
# Example: APP_REQUIREMENTS="requirements.txt"
APP_REQUIREMENTS=""

# Virtualenv directory (relative to repo root). Created automatically when
# APP_REQUIREMENTS is set; git-ignored.
APP_VENV="venv"
